{
  "name": "natours",
  "version": "1.0.0",
  "description": "learning node, express and mongoDB",
  "license": "ISC",
  "author": "Mahmoud Abbas",
  "type": "commonjs",
  "main": "app.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prestart": "npm run build:js",
    "start": "nodemon server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "heroku-postbuild": "npm run build:js:prod",
    "release": "node scripts/migrate-departures.js && node scripts/create-indexes.js",
    "reconcile:bookings": "node scripts/release-expired-reservations.js",
    "migrate:departures": "node scripts/migrate-departures.js",
    "build:js": "cross-env NODE_ENV=development node scripts/build-client.js",
    "build:js:prod": "cross-env NODE_ENV=production node scripts/build-client.js",
    "watch:js": "cross-env NODE_ENV=development node scripts/build-client.js --watch",
    "debug": "ndb server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.9.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "html-to-text": "^10.0.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "ndb": "^0.2.4",
    "nodemailer": "^9.0.3",
    "pug": "^3.0.4",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.35.3",
    "slugify": "^1.6.9",
    "stripe": "^22.3.1",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "validators/**/*.js",
      "!server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 65,
        "lines": 73,
        "statements": 71
      }
    }
  }
}
