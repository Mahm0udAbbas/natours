{
  "name": "natours",
  "version": "1.0.0",
  "description": "learning node, express and mongoDB",
  "license": "ISC",
  "author": "Mahmoud Abbas",
  "type": "commonjs",
  "main": "app.js",
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "start": "nodemon server.js",
    "start:prod": "cross-env NODE_ENV=production nodemon server.js",
    "debug": "ndb server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "ndb": "^0.2.4",
    "nodemailer": "^8.0.7",
    "sanitize-html": "^2.17.4",
    "slugify": "^1.6.9",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "validators/**/*.js",
      "!server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 65,
        "lines": 73,
        "statements": 71
      }
    }
  }
}
