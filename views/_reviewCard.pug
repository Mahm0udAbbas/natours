mixin reviewCard (review)
    article.reviews__card
        .reviews__avatar
            img.reviews__avatar-img(src=assetUrl(review.user.photo, 'users'), alt=`${review.user.name}`)
            div
                h3.reviews__user=review.user.name
                span.reviews__verified Verified traveler
        p.reviews__text=review.review
        .reviews__rating
            each star in [1,2,3,4,5]
                svg(class=`reviews__star reviews__star--${star <= review.rating ? 'active' : 'inactive'}`)
                    use(xlink:href='/img/icons.svg#icon-star')
